<article class="post-detail">
    <header class="post-header">
        <h1 class="post-title"><%- page.title %></h1>
        <div class="post-meta">
            <span>📅 发布于：<%- date(page.date, 'YYYY年MM月DD日') %></span>
            <% if (page.tags && page.tags.length) { %>
                <span class="tags">
                    🏷️ <%- list_tags(page.tags, {show_count: false, style: 'none', separator: ', '}) %>
                </span>
            <% } %>
        </div>
    </header>

    <div class="content markdown">
        <%- page.content %>
    </div>
</article>