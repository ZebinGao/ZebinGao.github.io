<article class="post-detail">
    <header class="post-header">
        <h1 class="post-title">分类</h1>
    </header>

    <div class="content markdown">
        <div class="wiki-categories">
            <% if (site.categories && site.categories.length) { %>
                <% site.categories.forEach(function(cat) { %>
                    <a class="wiki-category-card" href="<%- url_for(cat.path) %>">
                        <div class="wiki-category-name"><%- cat.name %></div>
                        <div class="wiki-category-desc"><%- cat.length %> 篇文章</div>
                    </a>
                <% }) %>
            <% } %>
        </div>
    </div>
</article>
