<div class="post-list">
    <% page.posts.each(function(post) { %>
        <article class="post-card">
            <h2 class="post-title">
                <a href="<%- url_for(post.path) %>"><%- post.title || '无标题文章' %></a>
            </h2>
            
            <div class="post-meta">
                <time>🕒 <%- date(post.date, 'YYYY-MM-DD') %></time>
            </div>
            
            <div class="post-excerpt">
                ，就只显示摘要，否则截取前 150 个字 -->
                <% if (post.excerpt) { %>
                    <%- post.excerpt %>
                <% } else { %>
                    <%- truncate(strip_html(post.content), {length: 150}) %>
                <% } %>
            </div>
            
            <a href="<%- url_for(post.path) %>" class="read-more">阅读全文 &raquo;</a>
        </article>
    <% }) %>
</div>

<nav class="paginator">
    <%- paginator({
        prev_text: '&laquo; 上一页',
        next_text: '下一页 &raquo;'
    }) %>
</nav>