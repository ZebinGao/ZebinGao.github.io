<article class="post-detail hobbies-page">
    <header class="post-header">
        <h1 class="post-title" data-i18n="hobbies">兴趣爱好</h1>
    </header>

    <div class="content markdown">
        <%- page.content %>

        <div class="link-category-tabs hobbies-main-tabs">
            <button class="category-tab active" data-filter="movies" data-i18n="movies">电影</button>
            <button class="category-tab" data-filter="books" data-i18n="books">书籍</button>
            <button class="category-tab" data-filter="music" data-i18n="music">音乐</button>
        </div>

        <div class="link-subcategory-tabs hobbies-status-tabs" data-parent="movies" style="display:flex;">
            <button class="category-tab active" data-filter="all" data-i18n="all">全部</button>
            <button class="category-tab" data-filter="watched" data-i18n="watched">已看</button>
            <button class="category-tab" data-filter="want_to_watch" data-i18n="want_to_watch">想看</button>
        </div>

        <div class="link-subcategory-tabs hobbies-status-tabs" data-parent="books" style="display:none;">
            <button class="category-tab active" data-filter="all" data-i18n="all">全部</button>
            <button class="category-tab" data-filter="read" data-i18n="read">已读</button>
            <button class="category-tab" data-filter="in_read" data-i18n="in_read">在读</button>
            <button class="category-tab" data-filter="want_to_read" data-i18n="want_to_read">想读</button>
        </div>

        <!-- 电影区域 -->
        <div class="hobbies-section" id="section-movies">
            <% if (site.data.movies) { %>
                <div class="movie-timeline">
                    <% var movies = site.data.movies.slice().reverse(); %>
                    <% movies.forEach(function(item) { %>
                        <% if (item.url) { %>
                            <a class="movie-item" href="<%- item.url %>" data-status="<%= item.status %>">
                        <% } else { %>
                            <div class="movie-item" data-status="<%= item.status %>">
                        <% } %>
                            <div class="movie-date"><%- item.date.substring(0, 10) %></div>
                            <div class="movie-info">
                                <span class="movie-title"><%- item.title %></span>
                                <% if (item.note) { %>
                                    <span class="movie-note">—— <%- item.note %></span>
                                <% } %>
                            </div>
                        <% if (item.url) { %>
                            </a>
                        <% } else { %>
                            </div>
                        <% } %>
                    <% }) %>
                </div>
            <% } %>
        </div>

        <!-- 书籍区域 -->
        <div class="hobbies-section" id="section-books" style="display:none;">
            <div class="hobbies-grid">
                <% if (site.data.books) { %>
                    <% site.data.books.forEach(function(item) { %>
                        <% if (item.url) { %>
                            <a class="hobby-card" href="<%- item.url %>" data-status="<%= item.status %>">
                        <% } else { %>
                            <div class="hobby-card" data-status="<%= item.status %>">
                        <% } %>
                            <div class="hobby-card-title"><%- item.title %></div>
                            <div class="hobby-card-meta">
                                <% if (item.author) { %><%- item.author %><% } %>
                                <% if (item.author && item.date) { %> · <% } %>
                                <% if (item.date) { %><%- item.date.substring(0, 4) %><% } %>
                            </div>
                            <% if (item.note) { %>
                                <div class="hobby-card-note"><%- item.note %></div>
                            <% } %>
                            <span class="hobby-status hobby-status-<%= item.status %>">
                                <%= item.status === 'read' ? '已读' : item.status === 'in_read' ? '在读' : '想读' %>
                            </span>
                        <% if (item.url) { %>
                            </a>
                        <% } else { %>
                            </div>
                        <% } %>
                    <% }) %>
                <% } %>
            </div>
        </div>

        <!-- 音乐区域 -->
        <div class="hobbies-section" id="section-music" style="display:none;">
            <div class="hobbies-grid">
                <% if (site.data.music) { %>
                    <% site.data.music.forEach(function(item) { %>
                        <% if (item.url) { %>
                            <a class="hobby-card music-card" href="<%- item.url %>" data-title="<%- item.title %>" data-artist="<%- item.artist || '' %>">
                        <% } else { %>
                            <div class="hobby-card music-card" data-title="<%- item.title %>" data-artist="<%- item.artist || '' %>">
                        <% } %>
                            <button class="music-play-btn" data-title="<%- item.title %>" data-artist="<%- item.artist || '' %>" data-audio="<%- item.audio || '' %>" title="播放">&#9654;</button>
                            <div class="hobby-card-title"><%- item.title %></div>
                            <div class="hobby-card-meta">
                                <% if (item.artist) { %><%- item.artist %><% } %>
                                <% if (item.artist && item.date) { %> &middot; <% } %>
                                <% if (item.date) { %><%- item.date.substring(0, 4) %><% } %>
                            </div>
                            <% if (item.note) { %>
                                <div class="hobby-card-note"><%- item.note %></div>
                            <% } %>
                        <% if (item.url) { %>
                            </a>
                        <% } else { %>
                            </div>
                        <% } %>
                    <% }) %>
                <% } %>
            </div>
        </div>
    </div>
</article>

<!-- 浮动音乐播放器 -->
<div class="music-player" id="musicPlayer">
    <div class="music-player-progress-wrap" id="playerProgressWrap">
        <div class="music-player-progress-bar" id="playerProgressBar"></div>
    </div>
    <div class="music-player-body">
        <button class="music-player-btn" id="playerPlayBtn" title="播放/暂停">&#9654;</button>
        <div class="music-player-info">
            <span class="music-player-title" id="playerTitle"></span>
            <span class="music-player-artist" id="playerArtist"></span>
        </div>
        <span class="music-player-time" id="playerTime">0:00 / 0:00</span>
        <button class="music-player-close" id="playerClose" title="关闭">&times;</button>
    </div>
</div>

<script>
(function() {
    var mainTabs = document.querySelector('.hobbies-main-tabs');
    var statusTabsAll = document.querySelectorAll('.hobbies-status-tabs');
    var sections = {
        movies: document.getElementById('section-movies'),
        books: document.getElementById('section-books'),
        music: document.getElementById('section-music')
    };
    var currentTab = 'movies';
    var currentStatus = 'all';

    function filterByStatus(section) {
        var cards = section.querySelectorAll('.hobby-card, .movie-item');
        cards.forEach(function(card) {
            var status = card.getAttribute('data-status');
            if (currentStatus === 'all' || status === currentStatus) {
                card.classList.remove('hidden');
            } else {
                card.classList.add('hidden');
            }
        });
    }

    mainTabs.addEventListener('click', function(e) {
        var tab = e.target.closest('.category-tab');
        if (!tab) return;

        mainTabs.querySelectorAll('.category-tab').forEach(function(t) { t.classList.remove('active'); });
        tab.classList.add('active');

        currentTab = tab.getAttribute('data-filter');
        currentStatus = 'all';

        // Show/hide sections
        Object.keys(sections).forEach(function(key) {
            sections[key].style.display = (key === currentTab) ? 'block' : 'none';
        });

        // Show/hide status tabs
        statusTabsAll.forEach(function(st) {
            if (st.getAttribute('data-parent') === currentTab) {
                st.style.display = 'flex';
                st.querySelectorAll('.category-tab').forEach(function(t) { t.classList.remove('active'); });
                st.querySelector('[data-filter="all"]').classList.add('active');
            } else {
                st.style.display = 'none';
            }
        });

        // Reset status filter
        filterByStatus(sections[currentTab]);
    });

    statusTabsAll.forEach(function(statusTabs) {
        statusTabs.addEventListener('click', function(e) {
            var tab = e.target.closest('.category-tab');
            if (!tab) return;

            statusTabs.querySelectorAll('.category-tab').forEach(function(t) { t.classList.remove('active'); });
            tab.classList.add('active');

            currentStatus = tab.getAttribute('data-filter');
            filterByStatus(sections[currentTab]);
        });
    });

    // ===== 音乐播放器 =====
    var base = 'https://raw.githubusercontent.com/ZebinGao/MyFavouriteMusic/main/%E9%9F%B3%E4%B9%90/';

    var audio = new Audio();
    var curTitle = '';
    var playerEl = document.getElementById('musicPlayer');
    var playBtns = document.querySelectorAll('.music-play-btn');

    // Show play buttons only for songs with audio files
    playBtns.forEach(function(b) {
        if (b.dataset.audio) b.classList.add('has-audio');
    });

    function fmt(s) {
        var m = Math.floor(s / 60), sec = Math.floor(s % 60);
        return m + ':' + (sec < 10 ? '0' : '') + sec;
    }

    function updateUI(playing) {
        document.getElementById('playerPlayBtn').innerHTML = playing ? '&#9646;&#9646;' : '&#9654;';
        playBtns.forEach(function(b) {
            if (b.dataset.title === curTitle) {
                b.innerHTML = playing ? '&#9646;&#9646;' : '&#9654;';
                b.closest('.music-card').classList.toggle('playing', playing);
            } else {
                b.innerHTML = '&#9654;';
            }
        });
    }

    function playSong(title, artist, file) {
        if (!file) return;
        if (curTitle === title && !audio.paused) {
            audio.pause(); updateUI(false); return;
        }
        if (curTitle !== title) { audio.src = base + encodeURIComponent(file); curTitle = title; }
        audio.play();
        document.getElementById('playerTitle').textContent = title;
        document.getElementById('playerArtist').textContent = artist;
        playerEl.classList.add('active');
        document.querySelectorAll('.music-card').forEach(function(c) { c.classList.remove('playing'); });
        updateUI(true);
    }

    playBtns.forEach(function(btn) {
        btn.addEventListener('click', function(e) {
            e.preventDefault(); e.stopPropagation();
            playSong(btn.dataset.title, btn.dataset.artist, btn.dataset.audio);
        });
    });

    document.getElementById('playerPlayBtn').addEventListener('click', function() {
        if (!curTitle) return;
        if (audio.paused) { audio.play(); updateUI(true); }
        else { audio.pause(); updateUI(false); }
    });

    document.getElementById('playerClose').addEventListener('click', function() {
        audio.pause(); audio.src = ''; curTitle = '';
        playerEl.classList.remove('active');
        document.querySelectorAll('.music-card').forEach(function(c) { c.classList.remove('playing'); });
        updateUI(false);
    });

    audio.addEventListener('timeupdate', function() {
        if (!audio.duration) return;
        var pct = (audio.currentTime / audio.duration) * 100;
        document.getElementById('playerProgressBar').style.width = pct + '%';
        document.getElementById('playerTime').textContent = fmt(audio.currentTime) + ' / ' + fmt(audio.duration);
    });

    audio.addEventListener('ended', function() { updateUI(false); });

    document.getElementById('playerProgressWrap').addEventListener('click', function(e) {
        if (!audio.duration) return;
        var rect = this.getBoundingClientRect();
        audio.currentTime = ((e.clientX - rect.left) / rect.width) * audio.duration;
    });
})();
</script>
