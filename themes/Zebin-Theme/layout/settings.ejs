<div class="settings-page">
    <h1 class="post-title" data-i18n="settings">设置</h1>

    <!-- 字体切换 -->
    <section class="settings-section">
        <h2 data-i18n="settings_font">字体</h2>
        <div class="settings-option">
            <span data-i18n="settings_font_desc">选择正文字体风格</span>
            <select class="settings-font-select" id="settings-font">
                <option value="default" data-i18n="settings_font_default">无衬线体</option>
                <option value="kai">楷体</option>
                <option value="huninn">jf open 粉圆</option>
                <option value="longchang">龙藏体</option>
                <option value="mashanzheng">马善政体</option>
                <option value="klee">Klee One</option>
                <option value="lxgw">霞鹜文楷</option>
                <option value="notoserif">思源宋体</option>
            </select>
        </div>
    </section>

    <!-- 字体大小 -->
    <section class="settings-section">
        <h2 data-i18n="settings_fontsize">字体大小</h2>
        <div class="settings-option">
            <span data-i18n="settings_fontsize_desc">调整正文字体大小</span>
            <select class="settings-font-select" id="settings-fontsize">
                <option value="14" data-i18n="settings_fontsize_small">小</option>
                <option value="16" data-i18n="settings_fontsize_default">默认</option>
                <option value="18" data-i18n="settings_fontsize_medium">中</option>
                <option value="20" data-i18n="settings_fontsize_large">大</option>
                <option value="22" data-i18n="settings_fontsize_xlarge">特大</option>
            </select>
        </div>
    </section>

    <!-- 主题切换 -->
    <section class="settings-section">
        <h2 data-i18n="settings_theme">外观主题</h2>
        <div class="settings-option">
            <span data-i18n="settings_theme_desc">选择明暗主题模式</span>
            <div class="settings-theme-buttons">
                <button class="settings-theme-btn" id="settings-theme-light" title="Light">
                    <span class="theme-icon">☀️</span>
                    <span data-i18n="settings_light">明亮</span>
                </button>
                <button class="settings-theme-btn" id="settings-theme-dark" title="Dark">
                    <span class="theme-icon">🌙</span>
                    <span data-i18n="settings_dark">暗黑</span>
                </button>
            </div>
        </div>
    </section>

    <!-- 语言切换 -->
    <section class="settings-section">
        <h2 data-i18n="settings_language">语言</h2>
        <div class="settings-option">
            <span data-i18n="settings_language_desc">选择界面显示语言</span>
            <div class="settings-lang-buttons">
                <button class="settings-lang-btn lang-btn" data-lang="zh" title="中文">中文</button>
                <button class="settings-lang-btn lang-btn" data-lang="en" title="English">English</button>
                <button class="settings-lang-btn lang-btn" data-lang="de" title="Deutsch">Deutsch</button>
            </div>
        </div>
    </section>

    <!-- RSS 订阅 -->
    <section class="settings-section">
        <h2 data-i18n="settings_rss">RSS 订阅</h2>
        <div class="settings-option">
            <span data-i18n="settings_rss_desc">通过 RSS 阅读器订阅博客更新</span>
            <a href="<%- url_for(theme.rss || 'atom.xml') %>" class="settings-rss-link" target="_blank">
                📡 <span data-i18n="settings_rss_subscribe">订阅 RSS</span>
            </a>
        </div>
    </section>
</div>

<script>
(function() {
    // === 字体切换 ===
    var fontMap = {
        'default': '-apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "PingFang SC", "Microsoft YaHei", sans-serif',
        'kai': '"KaiTi", "STKaiti", "Kaiti SC", serif',
        'huninn': '"Huninn", sans-serif',
        'longchang': '"Long Cang", cursive',
        'mashanzheng': '"Ma Shan Zheng", cursive',
        'klee': '"Klee One", serif',
        'lxgw': '"LXGW WenKai", serif',
        'notoserif': '"Noto Serif SC", "PingFang SC", serif'
    };

    var fontSelect = document.getElementById('settings-font');
    var savedFont = localStorage.getItem('font') || 'default';
    fontSelect.value = savedFont;

    // 页面加载时应用已保存的字体
    if (savedFont !== 'default' && fontMap[savedFont]) {
        document.documentElement.style.setProperty('--font-main', fontMap[savedFont]);
    }

    fontSelect.addEventListener('change', function() {
        var font = fontSelect.value;
        localStorage.setItem('font', font);
        if (font !== 'default' && fontMap[font]) {
            document.documentElement.style.setProperty('--font-main', fontMap[font]);
        } else {
            document.documentElement.style.removeProperty('--font-main');
        }
    });

    // === 字体大小 ===
    var fontsizeSelect = document.getElementById('settings-fontsize');
    var savedFontsize = localStorage.getItem('fontsize') || '16';
    fontsizeSelect.value = savedFontsize;

    if (savedFontsize !== '16') {
        document.documentElement.style.setProperty('--font-size', savedFontsize + 'px');
    }

    fontsizeSelect.addEventListener('change', function() {
        var size = fontsizeSelect.value;
        localStorage.setItem('fontsize', size);
        if (size !== '16') {
            document.documentElement.style.setProperty('--font-size', size + 'px');
        } else {
            document.documentElement.style.removeProperty('--font-size');
        }
    });

    // === 主题切换 ===
    var htmlElement = document.documentElement;
    var currentTheme = localStorage.getItem('theme');

    function updateThemeButtons(theme) {
        var lightBtn = document.getElementById('settings-theme-light');
        var darkBtn = document.getElementById('settings-theme-dark');
        if (theme === 'dark') {
            lightBtn.classList.remove('active');
            darkBtn.classList.add('active');
        } else {
            lightBtn.classList.add('active');
            darkBtn.classList.remove('active');
        }
    }

    // 初始化按钮状态
    updateThemeButtons(currentTheme);

    document.getElementById('settings-theme-light').addEventListener('click', function() {
        htmlElement.removeAttribute('data-theme');
        localStorage.setItem('theme', 'light');
        updateThemeButtons('light');
        var themeIcon = document.getElementById('theme-icon');
        if (themeIcon) themeIcon.innerText = '🌙';
    });

    document.getElementById('settings-theme-dark').addEventListener('click', function() {
        htmlElement.setAttribute('data-theme', 'dark');
        localStorage.setItem('theme', 'dark');
        updateThemeButtons('dark');
        var themeIcon = document.getElementById('theme-icon');
        if (themeIcon) themeIcon.innerText = '☀️';
    });
})();
</script>
