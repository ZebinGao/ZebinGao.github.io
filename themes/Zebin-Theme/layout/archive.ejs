<div class="archive-container">
    <% var lastYear = ''; var lastMonth = ''; %>

    <% page.posts.each(function(post) { %>
        <% var currentYear = post.date.format('YYYY'); %>
        <% var currentMonth = post.date.format('MM'); %>

        <% if (currentYear !== lastYear) { %>
            <% if (lastYear !== '') { %>
                </div></div>
            <% } %>
            <h2 class="archive-year"><%- currentYear %></h2>
            <div class="archive-year-block">
            <h3 class="archive-month"><%- currentMonth %> 月</h3>
            <div class="archive-list">
            <% lastYear = currentYear; lastMonth = currentMonth; %>
        <% } else if (currentMonth !== lastMonth) { %>
            </div>
            <h3 class="archive-month"><%- currentMonth %> 月</h3>
            <div class="archive-list">
            <% lastMonth = currentMonth; %>
        <% } %>

        <div class="archive-item">
            <time><%- post.date.format('MM-DD') %></time>
            <a href="<%- url_for(post.path) %>"><%- post.title || '无标题' %></a>
        </div>

    <% }) %>

    <% if (lastYear !== '') { %>
        </div></div>
    <% } %>

    <% if (page.total > 1) { %>
    <nav class="paginator">
        <% if (page.prev) { %>
            <a href="<%- url_for(page.prev_link) %>">&laquo;</a>
        <% } %>
        <% var start = Math.max(1, page.current - 2); %>
        <% var end = Math.min(page.total, start + 5); %>
        <% if (end - start < 5) { start = Math.max(1, end - 5); } %>
        <% if (start > 1) { %>
            <a href="<%- url_for(page.path) %>">1</a>
            <% if (start > 2) { %>
                <span class="paginator-ellipsis">...</span>
            <% } %>
        <% } %>
        <% for (var i = start; i <= end; i++) { %>
            <% if (i === page.current) { %>
                <span class="current"><%- i %></span>
            <% } else { %>
                <a href="<%- url_for(i === 1 ? page.path : 'archives/' + i + '/') %>"><%- i %></a>
            <% } %>
        <% } %>
        <% if (end < page.total) { %>
            <% if (end < page.total - 1) { %>
                <span class="paginator-ellipsis">...</span>
            <% } %>
            <a href="<%- url_for('archives/' + page.total + '/') %>"><%- page.total %></a>
        <% } %>
        <% if (page.next) { %>
            <a href="<%- url_for(page.next_link) %>">&raquo;</a>
        <% } %>
    </nav>
    <% } %>
</div>
