<div class="archive-container">
    <% var lastYear = ''; var lastMonth = ''; %>

    <% page.posts.each(function(post) { %>
        <% var currentYear = post.date.format('YYYY'); %>
        <% var currentMonth = post.date.format('MM'); %>

        <% if (currentYear !== lastYear) { %>
            <% if (lastYear !== '') { %>
                </div></div>
            <% } %>
            <h2 class="archive-year"><%- currentYear %></h2>
            <div class="archive-year-block">
            <h3 class="archive-month"><%- currentMonth %> 月</h3>
            <div class="archive-list">
            <% lastYear = currentYear; lastMonth = currentMonth; %>
        <% } else if (currentMonth !== lastMonth) { %>
            </div>
            <h3 class="archive-month"><%- currentMonth %> 月</h3>
            <div class="archive-list">
            <% lastMonth = currentMonth; %>
        <% } %>

        <div class="archive-item">
            <time><%- post.date.format('MM-DD') %></time>
            <a href="<%- url_for(post.path) %>"><%- post.title || '无标题' %></a>
        </div>

    <% }) %>

    <% if (lastYear !== '') { %>
        </div></div>
    <% } %>
</div>
