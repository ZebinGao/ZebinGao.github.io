<%- partial('_partial/head') %>
<body>
    <%- partial('_partial/mobile-header') %>
    <div class="main-container">
        <%- partial('_partial/sidebar-left') %>
        <main class="content-mid">
            <%- body %>
        </main>
        <%- partial('_partial/sidebar-right') %>
    </div>
    <script>window.__i18n_default = "<%- (theme.i18n && theme.i18n.default) || 'zh' %>";</script>
    <script>
    // 全局字体加载：从 localStorage 读取并立即应用，避免闪烁
    (function(){
        var fontMap = {
            'kai': '"KaiTi", "STKaiti", "Kaiti SC", serif',
            'huninn': '"Huninn", sans-serif',
            'longchang': '"Long Cang", cursive',
            'mashanzheng': '"Ma Shan Zheng", cursive',
            'klee': '"Klee One", serif',
            'lxgw': '"LXGW WenKai", serif',
            'notoserif': '"Noto Serif SC", "PingFang SC", serif'
        };
        var f = localStorage.getItem('font');
        if (f && f !== 'default' && fontMap[f]) {
            document.documentElement.style.setProperty('--font-main', fontMap[f]);
        }
        var fs = localStorage.getItem('fontsize');
        if (fs && fs !== '16') {
            document.documentElement.style.setProperty('--font-size', fs + 'px');
        }
        // 色调加载
        var tonePresets = {
            'rose':   { accent: '#d84b6b', rgb: '216, 75, 107',  accentDark: '#e05577', rgbDark: '224, 85, 119' },
            'blue':   { accent: '#3b82f6', rgb: '59, 130, 246',   accentDark: '#60a5fa', rgbDark: '96, 165, 250' },
            'purple': { accent: '#8b5cf6', rgb: '139, 92, 246',   accentDark: '#a78bfa', rgbDark: '167, 139, 250' },
            'orange': { accent: '#f59e0b', rgb: '245, 158, 11',   accentDark: '#fbbf24', rgbDark: '251, 191, 36' },
            'teal':   { accent: '#06b6d4', rgb: '6, 182, 212',    accentDark: '#22d3ee', rgbDark: '34, 211, 238' }
        };
        var t = localStorage.getItem('tone');
        if (t && t !== 'rose' && tonePresets[t]) {
            var p = tonePresets[t];
            var isDark = document.documentElement.getAttribute('data-theme') === 'dark';
            document.documentElement.style.setProperty('--accent', isDark ? p.accentDark : p.accent);
            document.documentElement.style.setProperty('--accent-rgb', isDark ? p.rgbDark : p.rgb);
        }
    })();
    </script>
    <%- js('js/theme-toggle') %>
    <%- js('js/calendar') %>
    <%- js('js/search') %>
    <%- js('js/mobile') %>
    <%- js('js/i18n') %>
    <%- partial('_partial/math') %>
</body>
</html>