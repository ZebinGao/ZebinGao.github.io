<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%- page.title ? page.title + ' | ' + config.title : config.title %></title>
    <%- css('css/style.css') %>
</head>
<body>
    <div class="main-container">
        
        <aside class="sidebar-left">
            <div class="avatar-box">
                <img src="https://via.placeholder.com/100" alt="Avatar" class="avatar">
                <h2 class="author-name"><%- config.author %></h2>
            </div>
            <nav class="site-nav">
                <a href="/">首页</a>
                <a href="/archives">归档</a>
                <a href="/about">关于我</a>
            </nav>
            <div class="social-links">
                <a href="#">GitHub</a>
                <a href="#">Email</a>
            </div>
        </aside>

        <main class="content-mid">
            <%- body %> 
        </main>

        <aside class="sidebar-right">
            <div class="widget">
                <h3>文章目录</h3>
                <div class="toc-content">这里稍后注入 TOC 数据</div>
            </div>
            <div class="widget">
                <h3>标签</h3>
                <div class="tags-content">这里稍后注入标签云</div>
            </div>
            <div class="widget">
                <h3>日历</h3>
                <div class="calendar-content">这里稍后写日历组件</div>
            </div>
        </aside>

    </div>
</body>
</html>