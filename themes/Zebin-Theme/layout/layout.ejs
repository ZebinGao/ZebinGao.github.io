<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%- page.title ? page.title + ' | ' + config.title : config.title %></title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/atom-one-dark.min.css">
    <%- css('css/style.css') %>
</head>
<body>
    <div class="main-container">
        
        <aside class="sidebar-left">
            <div class="avatar-box">
                <img src="<%- (typeof theme !== 'undefined' && theme.avatar) ? theme.avatar : '/img/avatar.png' %>" alt="Avatar" class="avatar">
                <h2 class="author-name"><%- config.author || 'ZeBin' %></h2>
                <p class="author-bio"><%- config.description || '保持热爱，奔赴山海。' %></p>
            </div>
            
            <nav class="site-nav">
                <% for (var name in theme.menu) { %>
                    <a href="<%- url_for(theme.menu[name]) %>">
                        <span><%- theme.menu_icons[name] || '📄' %></span> 
                        <%- name %>
                    </a>
                <% } %>
            </nav>
            
            <div class="social-links">
                <a href="https://github.com/zebingao" target="_blank" title="GitHub">GitHub</a>
                <a href="mailto:你的邮箱@xxx.com" target="_blank" title="Email">Email</a>
            </div>
        </aside>

        <main class="content-mid">
            <%- body %> 
        </main>

        <aside class="sidebar-right">
            
            <% if (is_post()) { %>
                <div class="widget toc-widget">
                    <h3><i class="iconfont icon-list"></i> 文章目录</h3>
                    <div class="toc-content">
                        <%- toc(page.content, {list_number: false}) %>
                    </div>
                </div>
            <% } %>

            <div class="widget tags-widget">
                <h3><i class="iconfont icon-tags"></i> 热门标签</h3>
                <div class="tags-cloud">
                    <%- tagcloud({min_font: 12, max_font: 20, amount: 30, color: true, start_color: '#999', end_color: '#d84b6b'}) %>
                </div>
            </div>

            <div class="widget calendar-widget">
                <h3><i class="iconfont icon-calendar"></i> 日历</h3>
                <div class="calendar-container">
                    <div class="calendar-header">
                        <span class="month" id="calendar-month"></span>
                    </div>
                    <div class="calendar-days">
                        <span>日</span><span>一</span><span>二</span><span>三</span><span>四</span><span>五</span><span>六</span>
                    </div>
                    <div class="calendar-grid" id="calendar-grid">
                        </div>
                </div>
            </div>
        </aside>

    </div>
    <script>
    function buildCalendar() {
        const grid = document.getElementById('calendar-grid');
        const monthHeader = document.getElementById('calendar-month'); // 🎯 获取标题元素
        if (!grid || !monthHeader) return;
        
        const now = new Date();
        const year = now.getFullYear();
        const month = now.getMonth();
        const today = now.getDate();
        
        // 🎯 动态写入当前的月份和年份
        const monthNames = ["一月", "二月", "三月", "四月", "五月", "六月", "七月", "八月", "九月", "十月", "十一月", "十二月"];
        monthHeader.innerText = `${monthNames[month]} ${year}`;
        
        const firstDay = new Date(year, month, 1).getDay();
        const daysInMonth = new Date(year, month + 1, 0).getDate();
        
        grid.innerHTML = ''; // 清空旧数据
        
        // 填充空白
        for (let i = 0; i < firstDay; i++) {
            grid.innerHTML += '<span></span>';
        }
        
        // 填充日期
        for (let d = 1; d <= daysInMonth; d++) {
            const isToday = d === today ? 'class="today"' : '';
            grid.innerHTML += `<span ${isToday}>${d}</span>`;
        }
    }
    buildCalendar();
</script>
</body>
</html>