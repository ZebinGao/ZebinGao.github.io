<!-- 移动端顶栏（桌面端隐藏） -->
<div class="mobile-header">
    <button class="mobile-hamburger" id="mobile-hamburger">☰</button>
    <span class="mobile-title"><%- config.title %></span>
    <button class="mobile-search-btn" id="mobile-search-btn">🔍</button>
    <a class="mobile-theme-toggle" id="mobile-theme-toggle" title="切换主题" style="cursor:pointer;">
        <span id="mobile-theme-icon">🌙</span>
    </a>
</div>
<div class="mobile-search-bar" id="mobile-search-bar">
    <input type="text" id="mobile-search-input" data-i18n-placeholder="search_placeholder" placeholder="搜索文章..." autocomplete="off">
    <div class="mobile-search-results" id="mobile-search-results"></div>
</div>
<div class="mobile-overlay" id="mobile-overlay"></div>