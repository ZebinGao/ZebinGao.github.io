<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%- page.title ? page.title + ' | ' + config.title : config.title %></title>
    <meta name="keywords" content="<%- theme.keywords %>">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/atom-one-dark.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css">
    <%- css('css/style.css') %>
    <% if (theme.favicon) { %>
    <link rel="icon" type="image/png" href="<%- theme.favicon %>">
    <% } %>
    <% if (theme.rss) { %>
    <link rel="alternate" type="application/atom+xml" href="<%- url_for(theme.rss) %>" title="<%- config.title %>">
    <% } %>
    <!-- Google Fonts: 字体切换功能所需 -->
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Huninn&family=Long+Cang&family=Ma+Shan+Zheng&family=Klee+One&family=Noto+Serif+SC:wght@400;700&family=LXGW+WenKai&display=swap">
</head>